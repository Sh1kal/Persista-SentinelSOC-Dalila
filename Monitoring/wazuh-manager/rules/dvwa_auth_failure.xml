<group name="dvwa,authentication_failed,">
  <rule id="100110" level="7">
    <if_sid>86600</if_sid>
    <field name="event_type" type="pcre2">^dvwa_auth_failure$</field>
    <field name="result" type="pcre2">^failure$</field>
    <description>DVWA authentication failure</description>
  </rule>

  <rule id="100111" level="12" frequency="5" timeframe="60">
    <if_matched_sid>100110</if_matched_sid>
    <same_source_ip />
    <description>DVWA brute-force login attempt: five authentication failures from $(srcip) within 60 seconds</description>
  </rule>
</group>
